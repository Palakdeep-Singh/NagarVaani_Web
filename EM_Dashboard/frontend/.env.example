# Client-side configuration
# Note: Vite requires environment variables to start with "VITE_" to expose them to the browser.
# DO NOT place server secrets (like service keys, encryption keys, or twilio tokens) here.

VITE_API_URL=http://localhost:5001/api
VITE_SUPABASE_URL=your_supabase_project_url

# Public anon key from Supabase dashboard (Do NOT use the service role key here)
VITE_SUPABASE_KEY=your_supabase_anon_public_key
